import java.util.*;

public class TwoSum {

    public static void main(String[] args) {

        Scanner sc = new Scanner(System.in);

        System.out.print("Tamanho do vetor: ");
        int n = sc.nextInt();

        int[] vetor = new int[n];

        for (int i = 0; i < n; i++) {
            vetor[i] = sc.nextInt();
        }

        System.out.print("Valor alvo (X): ");
        int x = sc.nextInt();

        HashMap<Integer, Integer> mapa = new HashMap<>();

        boolean encontrou = false;

        for (int i = 0; i < n; i++) {

            int complemento = x - vetor[i];

            if (mapa.containsKey(complemento)) {
                System.out.println("Par encontrado:");
                System.out.println("Índices: " + mapa.get(complemento) + " e " + i);
                System.out.println("Valores: " + complemento + " + " + vetor[i]);
                encontrou = true;
                break;
            }

            mapa.put(vetor[i], i);
        }

        if (!encontrou) {
            System.out.println("Nenhum par encontrado.");
        }

        sc.close();
    }
}
